{
  "_meta": {
    "description": "Custom technology fingerprints loaded as an overlay on top of the upstream Wappalyzer database. Adds detections for CMS platforms, hospitality and tourism booking engines, accommodation PMS, channel managers, CSS frameworks, and POS systems where the upstream fingerprints are insufficient or missing.",
    "notes": "Do not edit the a-z.json files (vendored from enthec/webappanalyzer). Add custom fingerprints here instead."
  },
  "_disabled": [
    "Element UI",
    "Cart Functionality",
    "Google Sites",
    "C3.js",
    "Contentful",
    "ZURB Foundation"
  ],
  "_disabled_meta": {
    "description": "Techs explicitly removed from the loaded DB after overlay merge. These upstream Wappalyzer fingerprints have well-known false-positive issues that no amount of pattern-tightening fixes (their HTML selectors match too-generic markup). Validated against tests/bench_tech_detect.py: disabling this list raises corpus precision from 0.621 -> ~0.9+ with no recall loss on the curated 10-site corpus.",
    "Element UI": "Matches generic 'el-' class prefixes used by countless unrelated component libraries. Fires on Stripe, Shopify, GitHub, Squarespace, etc.",
    "Cart Functionality": "Loose regex on cart-shaped patterns; fires on any site mentioning 'cart' or 'checkout' in marketing copy.",
    "Google Sites": "Pattern matches generic Google CSS - fires on any site that pulls a Google font or analytics asset.",
    "C3.js": "Generic chart-library pattern; fires on sites using unrelated charting code or with 'c3' in class names.",
    "Contentful": "Overbroad - fires on sites referencing the word 'contentful' or shipping similar SDK-style class names.",
    "ZURB Foundation": "Loose class-name match; fires on sites with unrelated 'foundation' word usage. Real Foundation usage has dropped sharply post-2020."
  },
  "_added_meta": {
    "description": "Overlay patches for upstream fingerprints that are outdated or missing. Each entry below extends or replaces a flawed upstream pattern.",
    "GSAP": "Upstream pattern only matches 'TweenMax.min.js' (GSAP 2.x). Modern GSAP 3.x ships as 'gsap.min.js' + plugin files (ScrollTrigger, SplitText, ...). The added patterns catch the 3.x shape.",
    "Amazon CloudFront": "Upstream entry exists but has zero detection patterns (scriptSrc=None, script=None, url=None). CloudFront is normally inferred from DNS CNAMEs which we can't see. Add a scriptSrc match on '*.cloudfront.net' which catches sites loading assets through CloudFront."
  },
  "Tailwind CSS": {
    "_overlay": true,
    "html": [
      "class=\"[^\"]*\\b(?:flex|grid|inline-flex)\\b[^\"]*\\b(?:items-center|justify-between|gap-\\d)\\b",
      "class=\"[^\"]*\\b(?:text-(?:sm|xs|lg|xl|2xl|3xl)|font-(?:bold|semibold|medium))\\b[^\"]*\\b(?:text-(?:gray|slate|zinc|neutral)-\\d{2,3}|bg-(?:white|black|gray|slate)-?\\d*)\\b",
      "class=\"[^\"]*\\bmax-w-(?:sm|md|lg|xl|2xl|7xl|screen-xl)\\b",
      "class=\"[^\"]*\\b(?:sm:|md:|lg:|xl:|2xl:)(?:flex|grid|hidden|block)\\b"
    ]
  },
  "GSAP": {
    "_overlay": true,
    "scriptSrc": [
      "/gsap[/-](\\d+\\.\\d+(?:\\.\\d+)?)/\\;version:\\1",
      "/gsap\\.min\\.js",
      "/gsap\\.js",
      "/ScrollTrigger\\.min\\.js",
      "/SplitText\\.min\\.js"
    ]
  },
  "Amazon CloudFront": {
    "_overlay": true,
    "scriptSrc": [
      "\\.cloudfront\\.net/"
    ],
    "html": [
      "<link[^>]+href=[\"'][^\"']*\\.cloudfront\\.net/",
      "<img[^>]+src=[\"'][^\"']*\\.cloudfront\\.net/"
    ]
  },
  "Craft CMS": {
    "_overlay": true,
    "html": [
      "<!-- Cached by Blitz on",
      "<!-- Generated by Craft CMS",
      "<input[^>]*name=[\"']CRAFT_CSRF_TOKEN[\"']",
      "csrfTokenName.*CRAFT_CSRF"
    ],
    "meta": {
      "generator": "Craft CMS",
      "csrf-param": "CRAFT_CSRF_TOKEN"
    },
    "dom": [
      "input[name='CRAFT_CSRF_TOKEN'][type='hidden']"
    ]
  },
